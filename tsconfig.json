{
	"compilerOptions": {
		"target": "ESNext",
		"module": "nodenext",
		"rootDir": "src",
		"declaration": true,
		"moduleResolution": "nodenext",
		"resolveJsonModule": true,
		"outDir": "dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"useUnknownInCatchVariables": true,
		"skipLibCheck": true
	}
}